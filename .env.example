# このファイルを .env にコピーして、xxx を自分の鍵に置き換える
#   cp .env.example .env   (Windowsは copy .env.example .env)
# 鍵は他人に見せない。.env はGit管理外(.gitignore済み)。

# Anthropic (Claude側) の鍵
#   取得: https://console.anthropic.com/ -> Settings -> API Keys
#   "sk-ant-" で始まる
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# OpenAI (Codex/GPT側) の鍵
#   取得: https://platform.openai.com/api-keys
#   "sk-" で始まる
OPENAI_API_KEY=sk-xxxxxxxx

# --- モデル選択（任意・鍵ではない）---
#   未指定ならアダプタ既定のまま（現状の挙動を変えない）。engawa.json の model.{resident,guest} にも書ける。
#   茶々(Claude): opus / claude-opus-4-8 / opus[1m] など（子 env の ANTHROPIC_MODEL 経由）
# ENGAWA_MODEL=claude-opus-4-8
#   客人(codex): gpt-5-codex など（codex-acp の CODEX_CONFIG 経由）
# ENGAWA_CODEX_MODEL=gpt-5-codex
