# secrets / local config（鍵を絶対にコミットしない）
.env
.env.local
.claude/settings.local.json

# 個人の挙動設定（鍵は入れないが端末ごとに調整＝管理外。雛形は engawa.json.sample）
engawa.json

# python
__pycache__/
*.py[cod]

# sqlite（永続化導入時に必要なら個別に外す）
*.db

# editor / os
.DS_Store
Thumbs.db
.vscode/
.idea/

# 素材置き場（Gemini 生成の生画像。現行アプリは assets/chacha.png を使用）
/assets/raw/

# codex のレビュー成果物（review-YYYY-MM-DD.md。本体リポでは追跡しない＝各自ローカル/codex 側で管理）
/codex/review-*.md
